<% content_for :title, "Lettre #{@newsletter.number}" %>
<% content_for :og_type, "article" %>
<% content_for :description, "Lettre #{@newsletter.number} du #{l(@newsletter.published_on, format: :long)}#{@newsletter.liturgical_context.present? ? " — #{@newsletter.liturgical_context}" : ""} : #{@newsletter.posts.map(&:title).join(", ").truncate(120)}" %>
<% if @newsletter.cover_image.attached? %>
  <% content_for :og_image, absolute_asset_url(@newsletter.cover_image) %>
<% end %>
<% content_for :json_ld do %>
  <script type="application/ld+json">
    <%== { "@context" => "https://schema.org", "@type" => "WebPage", "name" => "Lettre #{@newsletter.number} — Entre toutes les femmes", "datePublished" => @newsletter.published_on.iso8601, "url" => newsletter_url(@newsletter) }.to_json %>
  </script>
  <script type="application/ld+json">
    <%== { "@context" => "https://schema.org", "@type" => "BreadcrumbList", "itemListElement" => [ { "@type" => "ListItem", "position" => 1, "name" => "Accueil", "item" => root_url }, { "@type" => "ListItem", "position" => 2, "name" => "Les lettres", "item" => newsletters_url }, { "@type" => "ListItem", "position" => 3, "name" => "Lettre #{@newsletter.number}" } ] }.to_json %>
  </script>
<% end %>

<%# Breadcrumb %>
<div class="container">
  <nav aria-label="fil d'Ariane" class="newsletter-show-breadcrumb">
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Accueil", root_path %></li>
      <li class="breadcrumb-item"><%= link_to "Les lettres", newsletters_path %></li>
      <li class="breadcrumb-item active" aria-current="page">Lettre <%= @newsletter.number %></li>
    </ol>
  </nav>
</div>

<%# Hero %>
<section class="newsletter-show-hero">
  <div class="container">
    <div class="newsletter-show-hero-frame" <% if @newsletter.cover_image.attached? %>style="background-image: url('<%= url_for(@newsletter.cover_image.variant(resize_to_limit: [1400, 700])) %>')"<% end %>>
      <div class="newsletter-show-hero-overlay"></div>
      <div class="newsletter-show-hero-content">
        <i class="fa-regular fa-envelope newsletter-show-hero-icon"></i>
        <p class="newsletter-show-hero-number">Lettre <%= @newsletter.number %></p>
        <p class="newsletter-show-date"><%= l(@newsletter.published_on, format: :long) %></p>
        <% if @newsletter.liturgical_context.present? %>
          <em class="newsletter-show-context"><%= @newsletter.liturgical_context %></em>
        <% end %>
      </div>
    </div>
    <% if @newsletter.cover_caption.present? %>
      <p class="image-source"><%= @newsletter.cover_caption %></p>
    <% end %>
  </div>
</section>

<%# Posts %>
<div class="newsletter-show-body">
  <div class="container">
    <div class="newsletter-show-posts">
      <% @posts.each do |post| %>
        <article class="newsletter-show-post" id="post-<%= post.id %>">
          <span class="newsletter-show-post-theme"><%= post.theme.name %></span>
          <h2 class="newsletter-show-post-title"><%= post.title %></h2>
          <div class="post-content">
            <%= with_image_sources(post.content) %>
          </div>
          <% if current_user&.admin? %>
            <div class="newsletter-show-post-actions">
              <%= link_to "Modifier", edit_post_path(post), class: "btn btn-outline-secondary btn-sm" %>
            </div>
          <% end %>
        </article>
      <% end %>
    </div>

    <div class="newsletter-show-back">
      <%= link_to "← Toutes les lettres", newsletters_path, class: "btn btn-outline-primary btn-sm" %>
    </div>
  </div>
</div>
