<footer class="site-footer">

  <%# ── Subscribe card ── %>
  <div class="footer-subscribe-card-wrap">
    <div class="container">

      <%# Part 1 — Formulaire (blue border) %>
      <div class="footer-subscribe-card">
        <h2 class="footer-subscribe-card-title">
          <i class="fa-regular fa-envelope"></i> Recevoir la lettre
        </h2>
        <p class="footer-subscribe-card-tagline">Chaque dimanche, directement dans votre boîte mail.</p>
        <form class="footer-subscribe-form" action="BREVO_FORM_URL" method="post" accept-charset="utf-8" target="_blank">
          <input type="email" name="EMAIL" placeholder="Votre adresse e-mail" required>
          <button type="submit">S'abonner</button>
        </form>
      </div>

      <%# Part 2 — Vous aussi %>
      <div class="footer-subscribe-card-banner">
        <p class="footer-subscribe-card-banner-title">Vous aussi vous souhaitez partager</p>
        <p class="footer-subscribe-card-banner-body">un coup de cœur ❤, un enthousiasme, une émotion&nbsp;🤩😯💔😢💗💃😍 artistique&nbsp;?</p>
        <p class="footer-subscribe-card-banner-body">La semaine prochaine, nous pourrions savourer ensemble votre œuvre d'art&nbsp;🌟</p>
        <p class="footer-subscribe-card-banner-body">Partagez vos idées en nous écrivant à <a href="mailto:bonjour@entretouteslesfemmes.fr" class="footer-subscribe-card-link">bonjour@entretouteslesfemmes.fr</a></p>
      </div>

    </div>
  </div>

  <%# ── Main section : brand + categories ── %>
  <div class="footer-main">
    <div class="container">
      <div class="row g-5 align-items-start">

        <div class="col-12 col-md-5">
          <p class="footer-brand-title">Entre toutes <em>les femmes</em></p>
          <p class="footer-brand-tagline">Nourrir, encourager, éclairer</p>
        </div>

        <div class="col-12 col-md-7">
          <div class="row g-2 justify-content-end">
            <% @nav_themes&.each do |theme| %>
              <div class="col-6">
                <%= link_to theme.name, theme_path(theme), class: "footer-theme-link" %>
              </div>
            <% end %>
            <div class="col-6">
              <%= link_to "Toutes les lettres", newsletters_path, class: "footer-theme-link" %>
            </div>
          </div>
        </div>

      </div>

      <div class="footer-email-row">
        <a href="mailto:bonjour@entretouteslesfemmes.fr" class="footer-email-link">
          <i class="fa-regular fa-envelope"></i>
          bonjour@entretouteslesfemmes.fr
        </a>
      </div>

    </div>
  </div>

  <%# ── Bottom bar ── %>
  <div class="footer-bottom">
    <div class="container">
      <span>&copy; <%= Date.today.year %> Entre toutes les femmes</span>
    </div>
  </div>

</footer>
