<%# ============================================================
    Banner — call to action
    ============================================================ %>
<div class="footer-banner">
  <div class="footer-banner-inner">
    <p class="footer-banner-title">Vous aussi vous souhaitez partager</p>
    <p class="footer-banner-body">un coup de cœur ❤, un enthousiasme, une émotion&nbsp;🤩😯💔😢💗💃😍 artistique&nbsp;?</p>
    <p class="footer-banner-body">La semaine prochaine, nous pourrions savourer ensemble votre œuvre d'art&nbsp;🌟</p>
    <p class="footer-banner-body">Qu'en dites-vous&nbsp;?</p>
    <p class="footer-banner-body">Partagez vos idées en nous écrivant à <a href="mailto:bonjour@entretouteslesfemmes.fr" class="footer-banner-link">bonjour@entretouteslesfemmes.fr</a></p>
  </div>
</div>

<footer class="site-footer">

  <%# ── Subscription section ── %>
  <div class="footer-subscribe">
    <div class="container">
      <div class="footer-subscribe-inner">
        <p class="footer-subscribe-title">Recevoir la lettre</p>
        <p class="footer-subscribe-desc">Chaque dimanche, directement dans votre boîte mail.</p>
        <form class="footer-subscribe-form" action="BREVO_FORM_URL" method="post" accept-charset="utf-8" target="_blank">
          <input type="email" name="EMAIL" placeholder="Votre adresse e-mail" required>
          <button type="submit">S'abonner</button>
        </form>
      </div>
    </div>
  </div>

  <%# ── Main section : brand + categories ── %>
  <div class="footer-main">
    <div class="container">
      <div class="row g-5 align-items-start">

        <div class="col-12 col-md-5">
          <p class="footer-brand-title">Entre toutes <em>les femmes</em></p>
          <p class="footer-brand-tagline">Nourrir, encourager, éclairer</p>
          <a href="mailto:bonjour@entretouteslesfemmes.fr" class="footer-brand-email">bonjour@entretouteslesfemmes.fr</a>
        </div>

        <div class="col-12 col-md-7">
          <div class="row g-2">
            <% @nav_themes&.each do |theme| %>
              <div class="col-6">
                <%= link_to theme.name, theme_path(theme), class: "footer-theme-link" %>
              </div>
            <% end %>
          </div>
        </div>

      </div>
    </div>
  </div>

  <%# ── Bottom bar ── %>
  <div class="footer-bottom">
    <div class="container">
      <span>&copy; <%= Date.today.year %> Entre toutes les femmes</span>
    </div>
  </div>

</footer>
