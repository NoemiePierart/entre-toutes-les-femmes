<!DOCTYPE html>
<html lang="fr">
  <head>
    <% _page_title = yield(:title) %>
    <title><%= _page_title.present? ? "#{_page_title} — Entre toutes les femmes" : "Entre toutes les femmes" %></title>
    <% _page_description = yield(:description).presence || "Entre toutes les femmes — une lettre hebdomadaire pour nourrir, encourager et éclairer les femmes chrétiennes." %>
    <meta name="description" content="<%= _page_description %>">

    <%# Open Graph %>
    <meta property="og:site_name" content="Entre toutes les femmes">
    <meta property="og:type" content="<%= yield(:og_type).presence || "website" %>">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:title" content="<%= raw(_page_title.presence || "Entre toutes les femmes") %>">
    <meta property="og:description" content="<%= _page_description %>">
    <% if (_og_image = yield(:og_image)).present? %>
      <meta property="og:image" content="<%= _og_image %>">
      <meta name="twitter:image" content="<%= _og_image %>">
    <% end %>

    <%# Twitter Card %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= raw(_page_title.presence || "Entre toutes les femmes") %>">
    <meta name="twitter:description" content="<%= _page_description %>">

    <%# Canonical URL %>
    <link rel="canonical" href="<%= request.base_url + request.path %>">

    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Entre toutes les femmes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>
    <%= yield :json_ld %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Gentium+Book+Basic:ital@0;1&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Gentium+Book+Basic:ital@0;1&family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&display=swap"></noscript>
    <link rel="preconnect" href="https://res.cloudinary.com">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body><%= render "shared/navbar" %>
<%= render "shared/flashes" %>

    <%= yield %>
    <%= render "shared/footer" %>
  </body>
</html>
