<% content_for :title, "Entre toutes les femmes" %>

<%# Hero %>
<section class="hero">
  <div class="hero-inner container">
    <h1 class="hero-title">
      Entre toutes<br><em>les femmes</em>
    </h1>
    <p class="hero-tagline">Nourrir, encourager, éclairer</p>
    <p class="hero-description">
      Une lettre hebdomadaire qui encourage les femmes chrétiennes à vivre leur féminité de manière unifiée,
      en leur offrant un contenu riche de sens et beau pour nourrir leur être intérieur.
    </p>
    <div class="hero-rubriques">
      <% @themes.each do |theme| %>
        <div class="hero-rubrique">
          <span class="hero-rubrique-name"><%= theme.name %></span>
        </div>
      <% end %>
    </div>
  </div>
</section>

<%# Recent newsletters %>
<section id="lettres" class="container py-5 blog-index">
  <% if @newsletters.any? %>
    <% @newsletters.each do |newsletter| %>
      <%= link_to newsletter_path(newsletter), class: "newsletter-card text-decoration-none" do %>
        <% if newsletter.cover_image.attached? %>
          <div class="newsletter-card-image" style="background-image: url('<%= url_for(newsletter.cover_image.variant(resize_to_limit: [360, 240])) %>')"></div>
        <% else %>
          <div class="newsletter-card-image newsletter-card-image--empty"></div>
        <% end %>
        <div class="newsletter-card-body">
          <div class="newsletter-card-meta">
            <span class="newsletter-card-number">Lettre <%= newsletter.number %></span>
            <span class="newsletter-card-date"><%= l(newsletter.published_on, format: :long) %></span>
            <% if newsletter.liturgical_context.present? %>
              <em class="newsletter-card-context"><%= newsletter.liturgical_context %></em>
            <% end %>
          </div>
          <ul class="newsletter-card-posts">
            <% newsletter.posts.each do |post| %>
              <li>
                <span class="newsletter-card-post-theme"><%= post.theme.name %></span>
                <%= post.title %>
              </li>
            <% end %>
          </ul>
        </div>
      <% end %>
    <% end %>

    <div class="text-center mt-5">
      <%= link_to "Voir la suite", newsletters_path, class: "btn btn-outline-primary" %>
    </div>
  <% else %>
    <p class="text-muted">Aucune lettre pour le moment.</p>
  <% end %>
</section>
