          <div class="home-hero-overlay"></div>
          <div class="home-hero-content">
            <h1 class="home-hero-title">Entre toutes<br><em>les femmes</em></h1>
            <p class="home-hero-tagline">Nourrir, encourager, éclairer</p>
          </div>
        </div>
      </div>
    </section>
    <% end %>
  </div>
</div>
