<% content_for :title, @theme.name %>

<div class="container py-5 blog-index">
  <h1 class="blog-index-title mb-4"><%= @theme.name %></h1>

  <% if @posts.any? %>
    <div class="row g-4">
      <% @posts.each do |post| %>
        <div class="col-md-6 col-lg-4">
          <%= link_to post, class: "card h-100 post-card text-decoration-none" do %>
            <% if post.thumbnail.attached? %>
              <%= image_tag post.thumbnail.variant(resize_to_limit: [800, 400]), class: "card-img-top post-card-thumbnail" %>
            <% end %>
            <div class="card-body">
              <h5 class="card-title"><%= post.title %></h5>
              <p class="card-text text-muted small mb-1"><%= l(post.newsletter.published_on, format: :long) %></p>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">Aucun article dans cette rubrique pour le moment.</p>
  <% end %>
</div>
