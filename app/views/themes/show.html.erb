<% content_for :title, @theme.name %>
<% content_for :description, @theme.description.presence || "Découvrez les articles de la rubrique #{@theme.name} — Entre toutes les femmes." %>
<% content_for :og_image, request.base_url + "/og-theme-#{@theme.name.parameterize}.png" %>

<div class="theme-show-page">

  <%# Hero — pleine largeur %>
  <div class="theme-show-hero-frame" <% if @theme.image.attached? %>style="background-image: url('<%= variant_url(@theme.image, resize_to_limit: [1400, 800], format: :webp) %>')"<% end %>>
    <div class="theme-show-hero-overlay"></div>
    <div class="theme-show-hero-content">
      <span class="theme-show-hero-rubrique">Rubrique</span>
      <h1 class="theme-show-hero-title"><%= @theme.name %></h1>
    </div>
  </div>

  <%# Carte flottante — description seule %>
  <% if @theme.description.present? %>
    <div class="theme-show-desc-wrap">
      <div class="theme-show-desc-card">
        <p class="theme-show-desc-text"><%= @theme.description %></p>
      </div>
    </div>
  <% end %>

  <%# Posts %>
  <div class="theme-show-posts">
    <% if @posts.any? %>
      <div class="d-flex justify-content-center mb-4">
        <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
      </div>
      <div class="theme-cards">
        <% @posts.each do |post| %>
          <%= link_to post, class: "theme-card text-decoration-none" do %>
            <div class="theme-card-image">
              <% if post.cover_image? %>
                <%= image_tag variant_url(post.cover_image, resize_to_limit: [800, 500], format: :webp), class: "theme-card-image-bg", alt: post.title, loading: "lazy" %>
              <% end %>
            </div>
            <div class="theme-card-desc">
              <h3 class="post-card-title"><%= post.display_title %></h3>
              <p class="post-card-date"><%= l(post.newsletter.published_on, format: :long) %></p>
            </div>
          <% end %>
        <% end %>
      </div>
      <div class="d-flex justify-content-center mt-5">
        <%== pagy_bootstrap_nav(@pagy) if @pagy.pages > 1 %>
      </div>
    <% else %>
      <p class="text-muted">Aucun article dans cette rubrique pour le moment.</p>
    <% end %>
  </div>

</div>
