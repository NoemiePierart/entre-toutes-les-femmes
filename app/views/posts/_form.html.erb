<%= simple_form_for post do |f| %>
  <%= f.error_notification %>

  <%= f.input :title, label: "Titre" %>
  <%= f.association :newsletter,
        collection: Newsletter.order(published_on: :desc),
        label_method: ->(n) { "Lettre #{n.number} — #{l(n.published_on, format: :long)}" },
        value_method: :id,
        include_blank: "Choisir une lettre",
        label: "Lettre" %>
  <%= f.association :theme,
        collection: Theme.order(:name),
        label_method: :name,
        value_method: :id,
        include_blank: "Choisir un thème",
        label: "Thème" %>
  <%= f.input :content, as: :rich_text_area, label: "Contenu" %>

  <%= f.submit class: "btn btn-primary mt-3" %>
<% end %>
