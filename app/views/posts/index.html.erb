<% content_for :title, "Blog" %>

<div class="container py-5 blog-index">
  <div class="d-flex justify-content-between align-items-baseline mb-4">
    <h1>Blog</h1>
    <% if current_user&.admin? %>
      <%= link_to "Nouvel article", new_post_path, class: "btn btn-outline-primary btn-sm" %>
    <% end %>
  </div>

  <% if @posts.any? %>
    <div class="row g-4">
      <% @posts.each do |post| %>
        <div class="col-md-6 col-lg-4">
          <%= link_to post, class: "card h-100 post-card text-decoration-none" do %>
            <div class="card-body">
              <span class="badge mb-2"><%= post.theme.name %></span>
              <h5 class="card-title"><%= post.title %></h5>
              <p class="card-text text-muted small"><%= l(post.newsletter.published_on, format: :long) %></p>
            </div>
          <% end %>
          <% if current_user&.admin? %>
            <div class="d-flex gap-2 mt-1">
              <%= link_to "Modifier", edit_post_path(post), class: "btn btn-sm btn-outline-secondary" %>
              <%= link_to "Supprimer", post, data: { turbo_method: :delete, turbo_confirm: "Supprimer cet article ?" }, class: "btn btn-sm btn-outline-danger" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">Aucun article pour le moment.</p>
  <% end %>
</div>
