<div class="devise-container">
  <h2>Modifier mon compte</h2>

  <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
    <%= f.error_notification %>

    <div class="form-inputs">
      <%= f.input :email, label: "Adresse e-mail", required: true, autofocus: true %>

      <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
        <p>En attente de confirmation pour : <%= resource.unconfirmed_email %></p>
      <% end %>

      <div data-controller="password-visibility">
        <%= f.input :password,
                    label: "Nouveau mot de passe",
                    hint: "Laisser vide pour ne pas le modifier",
                    required: false,
                    input_html: { autocomplete: "new-password", data: { "password-visibility-target": "input" } } %>
        <button type="button" class="password-toggle" data-action="click->password-visibility#toggle" tabindex="-1" aria-label="Afficher / masquer le mot de passe">
          <i class="fa-regular fa-eye" data-password-visibility-target="icon"></i>
        </button>
      </div>
      <div data-controller="password-visibility">
        <%= f.input :password_confirmation,
                    label: "Confirmer le nouveau mot de passe",
                    required: false,
                    input_html: { autocomplete: "new-password", data: { "password-visibility-target": "input" } } %>
        <button type="button" class="password-toggle" data-action="click->password-visibility#toggle" tabindex="-1" aria-label="Afficher / masquer le mot de passe">
          <i class="fa-regular fa-eye" data-password-visibility-target="icon"></i>
        </button>
      </div>
      <div data-controller="password-visibility">
        <%= f.input :current_password,
                    label: "Mot de passe actuel",
                    hint: "Requis pour valider les modifications",
                    required: true,
                    input_html: { autocomplete: "current-password", data: { "password-visibility-target": "input" } } %>
        <button type="button" class="password-toggle" data-action="click->password-visibility#toggle" tabindex="-1" aria-label="Afficher / masquer le mot de passe">
          <i class="fa-regular fa-eye" data-password-visibility-target="icon"></i>
        </button>
      </div>
    </div>

    <div class="form-actions">
      <%= f.button :submit, "Enregistrer les modifications" %>
    </div>
  <% end %>

  <h3 class="mt-5">Supprimer mon compte</h3>
  <p><%= button_to "Supprimer mon compte", registration_path(resource_name), data: { turbo_confirm: "Êtes-vous sûre de vouloir supprimer votre compte ?" }, method: :delete, class: "btn btn-outline-danger btn-sm" %></p>

  <%= link_to "Retour", :back, class: "text-muted small" %>
</div>
