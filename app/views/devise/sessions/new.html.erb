<div class="devise-container">
  <h2>Connexion</h2>

  <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <div class="form-inputs">
      <%= f.input :email,
                  label: "Adresse e-mail",
                  required: false,
                  autofocus: true,
                  input_html: { autocomplete: "email" } %>
      <div data-controller="password-visibility">
        <%= f.input :password,
                    label: "Mot de passe",
                    required: false,
                    input_html: { autocomplete: "current-password", data: { "password-visibility-target": "input" } } %>
        <button type="button" class="password-toggle" data-action="click->password-visibility#toggle" tabindex="-1" aria-label="Afficher / masquer le mot de passe">
          <i class="fa-regular fa-eye" data-password-visibility-target="icon"></i>
        </button>
      </div>
      <%= f.input :remember_me, label: "Se souvenir de moi", as: :boolean if devise_mapping.rememberable? %>
    </div>

    <div class="form-actions">
      <%= f.button :submit, "Se connecter" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
