<div class="devise-container">
  <h2>Changer mon mot de passe</h2>

  <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
    <%= f.error_notification %>

    <%= f.input :reset_password_token, as: :hidden %>
    <%= f.full_error :reset_password_token %>

    <div class="form-inputs">
      <div data-controller="password-visibility">
        <%= f.input :password,
                    label: "Nouveau mot de passe",
                    required: true,
                    autofocus: true,
                    hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
                    input_html: { autocomplete: "new-password", data: { "password-visibility-target": "input" } } %>
        <button type="button" class="password-toggle" data-action="click->password-visibility#toggle" tabindex="-1" aria-label="Afficher / masquer le mot de passe">
          <i class="fa-regular fa-eye" data-password-visibility-target="icon"></i>
        </button>
      </div>
      <div data-controller="password-visibility">
        <%= f.input :password_confirmation,
                    label: "Confirmer le nouveau mot de passe",
                    required: true,
                    input_html: { autocomplete: "new-password", data: { "password-visibility-target": "input" } } %>
        <button type="button" class="password-toggle" data-action="click->password-visibility#toggle" tabindex="-1" aria-label="Afficher / masquer le mot de passe">
          <i class="fa-regular fa-eye" data-password-visibility-target="icon"></i>
        </button>
      </div>
    </div>

    <div class="form-actions">
      <%= f.button :submit, "Changer mon mot de passe" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</div>
